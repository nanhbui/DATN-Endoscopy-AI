# ── Endoscopy AI — environment template ──────────────────────────────────────
# Usage:
#   make env-init        ← copies sections to src/backend/api/.env and frontend/.env.local
#   OR copy manually:
#     cp configs/.env.example src/backend/api/.env   (then edit)
#     cp configs/.env.example frontend/.env.local    (then edit)
#
# DO NOT commit actual .env files to git.

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND  (src/backend/api/.env)
# ═══════════════════════════════════════════════════════════════════════════════

# ── OpenAI (required for LLM explanations) ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

# ── LangSmith tracing (optional) ─────────────────────────────────────────────
# LANGCHAIN_API_KEY=...
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=endoscopy-ai

# ── Upload directory (default: repo_root/data/uploads) ───────────────────────
# ENDOSCOPY_UPLOAD_DIR=/path/to/uploads

# ── YOLO model path ───────────────────────────────────────────────────────────
# ENDOSCOPY_MODEL=/path/to/daday.pt

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_DIR=/path/to/logs

# ── GstShark profiling (optional) ────────────────────────────────────────────
# Set to true to enable GStreamer pipeline profiling via GstShark tracers.
# Requires GstShark built at GSTSHARK_PLUGIN_PATH on the GPU server.
ENABLE_GSTSHARK_PROFILING=false
# GSTSHARK_PLUGIN_PATH=/home/emie/DATN_ver0/gst-shark-install/lib/gstreamer-1.0
# GSTSHARK_LOG_DIR=/tmp/gst-shark
# GSTSHARK_TRACERS=framerate;proctime;interlatency

# ═══════════════════════════════════════════════════════════════════════════════
# FRONTEND  (frontend/.env.local)
# ═══════════════════════════════════════════════════════════════════════════════

# FastAPI backend URL visible to the browser (no trailing slash)
NEXT_PUBLIC_API_BASE=http://localhost:8001

# Server-side Winston log level
# LOG_LEVEL=info
