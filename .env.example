# Command: cp .env.example .env

# ============================================================================
# REQUIRED: API Keys
# ============================================================================

# OpenAI API Key (REQUIRED)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=...

# MongoDB Connection URI (REQUIRED)
# Local MongoDB: mongodb://localhost:27017/
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017/

# ============================================================================
# OPTIONAL: LLM Configuration
# ============================================================================

# OpenAI Model (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# OpenAI Embedding Model (default: text-embedding-3-small)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ============================================================================
# OPTIONAL: LangSmith Tracing (Debugging & Monitoring)
# ============================================================================

# LangSmith API Key (optional, for tracing/debugging)
# Get it from: https://smith.langchain.com/
# Sign up at LangSmith, create a new API key, and paste it here
LANGCHAIN_API_KEY=...

# Enable/disable LangSmith tracing (true/false)
# Set to "true" to enable tracing in LangSmith dashboard
LANGCHAIN_TRACING_V2=true

# LangSmith Project Name (optional, default: product-rag-chatbot)
# This organizes your traces in the LangSmith dashboard
LANGCHAIN_PROJECT=product-rag-chatbot

# LangSmith Endpoint (optional, use default unless using enterprise)
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

CAMERA_ID=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=30

# ============================================================================
# Phase 1: Capture System Configuration
# ============================================================================

# YOLO model configuration
# Options: yolov8n.pt (detection only), yolov8n-seg.pt (segmentation + background removal)
# Using segmentation model enables transparent PNG output with background removed
YOLO_MODEL=yolov8n-seg.pt

# Number of angles to capture per product
TOTAL_ANGLES=3

# Minimum bounding box area for quality assessment (pixels)
MIN_BBOX_AREA=10000

# Output directory for captured images
OUTPUT_DIR=captured_images

# ============================================================================
# Phase 1: GstShark Performance Profiling (Optional)
# ============================================================================

# Enable GstShark profiling for GStreamer pipeline performance analysis
# Requires GstShark installed: https://github.com/RidgeRun/gst-shark
# Set to 'true' to enable detailed performance metrics (FPS, latency, CPU usage)
ENABLE_GSTSHARK_PROFILING=false

BLUR_THRESHOLD=100.0

MIN_CONTRAST_STD=20.0

# Edge margin ratio (0.0 to 1.0)
EDGE_MARGIN_RATIO=0.1

DEBUG=false

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path
LOG_FILE=./logs/app.log

TAVILY_API_KEY=...