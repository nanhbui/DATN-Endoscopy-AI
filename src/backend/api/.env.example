# Backend environment — copy to .env and fill in values
# DO NOT commit .env to git

# ── OpenAI (required for LLM explanations) ───────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001

# ── Upload directory (default: repo_root/data/uploads) ───────────────────────
# ENDOSCOPY_UPLOAD_DIR=/path/to/uploads

# ── YOLO model path ───────────────────────────────────────────────────────────
# ENDOSCOPY_MODEL=/path/to/daday.pt

# ── Pipeline module directory (only if running from a different cwd) ─────────
# PIPELINE_DIR=/path/to/src/backend/pipeline

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# LOG_DIR=/path/to/logs    # default: src/backend/api/logs/
